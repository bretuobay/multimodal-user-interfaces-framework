{
  "name": "@muix/solid",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "description": "Solid.js primitives for the MUIX framework",
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
