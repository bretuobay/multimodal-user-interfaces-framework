  "devDependencies": {
    "@repo/typescript-config": "*",
    "jsdom": "^26.1.0",
    "solid-js": "^1.9.11",
    "typescript": "5.9.2",
    "vite": "^6.3.0",
    "vite-plugin-dts": "^4.5.3",
    "vitest": "^3.2.0"
  }
