{
  "name": "@muix/policy",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "description": "Policy engine for permissions, concurrency, and rate limiting in MUIX",
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
